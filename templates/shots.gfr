Gaffer.Metadata.registerValue( __children["shot_0010"]["renderLayers"]["SpreadsheetOptions"]["rows"][0]["cells"]["aaSamples"], 'spreadsheet:section', 'samples' )
Gaffer.Metadata.registerValue( __children["shot_0010"]["renderLayers"]["SpreadsheetOptions"]["rows"][0]["cells"]["aaSamples"], 'spreadsheet:columnIndex', 28 )
