Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["scene_visible_off"], 'spreadsheet:section', 'layer' )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["scene_visible_off"], 'spreadsheet:columnIndex', 43 )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["scene_visible_off"], 'spreadsheet:columnWidth', 219 )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["scene_visible_off"]["value"], 'renameable', True )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["scene_visible_off"]["value"], 'description', "A set expression that computes a set that defines\nthe locations to be matched.\n\nFor example, the expression `mySpheresSet | myCubesSet`\nwill create a set that contains all objects in\n`mySpheresSet` and `myCubesSet`.\n\nGaffer supports the union operator (`|`) as shown in the\nexample and also provides intersection (`&`) and difference (`-`)\noperations for set expressions. Names of locations\ncan be used to represent a set that contains only\nthat one location.\n\nIn addition, the `in` and `containing` operators can be\nused to query descendant and ancestor matches. For example,\n`materialA in assetB` will select all locations in the `materialA`\nset that are at or below locations in the `assetB` set. This\nallows leaf matches to be made against sets that only contain\nroot or parent locations. `allAssets containing glass` will\nselection locations in `allAssets` that have children in the\n`glass` set.\n\nFor more examples please consult the Scripting Reference\nsection in Gaffer's documentation.\n\nThe context menu of the set expression text field provides\nentries that help construct set expressions." )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["scene_visible_off"]["value"], 'ui:scene:acceptsSetExpression', True )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["scene_visible_off"]["value"], 'nodule:type', '' )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["camera_off"], 'spreadsheet:section', 'layer' )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["camera_off"], 'spreadsheet:columnIndex', 42 )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["camera_off"], 'spreadsheet:columnLabel', 'camera_on' )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["camera_off"], 'spreadsheet:columnWidth', 344 )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["camera_off"]["value"], 'renameable', True )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["camera_off"]["value"], 'description', "A set expression that computes a set that defines\nthe locations to be matched.\n\nFor example, the expression `mySpheresSet | myCubesSet`\nwill create a set that contains all objects in\n`mySpheresSet` and `myCubesSet`.\n\nGaffer supports the union operator (`|`) as shown in the\nexample and also provides intersection (`&`) and difference (`-`)\noperations for set expressions. Names of locations\ncan be used to represent a set that contains only\nthat one location.\n\nIn addition, the `in` and `containing` operators can be\nused to query descendant and ancestor matches. For example,\n`materialA in assetB` will select all locations in the `materialA`\nset that are at or below locations in the `assetB` set. This\nallows leaf matches to be made against sets that only contain\nroot or parent locations. `allAssets containing glass` will\nselection locations in `allAssets` that have children in the\n`glass` set.\n\nFor more examples please consult the Scripting Reference\nsection in Gaffer's documentation.\n\nThe context menu of the set expression text field provides\nentries that help construct set expressions." )
Gaffer.Metadata.registerValue( __children["seq0002"]["renderLayers1"]["rows"][0]["cells"]["camera_off"]["value"], 'ui:scene:acceptsSetExpression', True )
