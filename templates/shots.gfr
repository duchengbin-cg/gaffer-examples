Gaffer.Metadata.registerValue( __children["shot_0010"]["renderLayers"]["SpreadsheetOptions"]["rows"][0]["cells"]["aaSamples"]["value"], 'description', 'Controls the number of rays per pixel\ntraced from the camera. The more samples,\nthe better the quality of antialiasing,\nmotion blur and depth of field. The actual\nnumber of rays per pixel is the square of\nthe AA samples value - so a value of 3\nmeans 9 rays are traced, 4 means 16 rays are\ntraced and so on.' )
Gaffer.Metadata.registerValue( __children["shot_0010"]["renderLayers"]["SpreadsheetOptions"]["rows"][0]["cells"]["aaSamples"]["value"], 'label', 'AA Samples' )
