Gaffer.Metadata.registerValue( __children["context_selector"]["updateLayerMenu"], 'buttonPlugValueWidget:clicked', 'import Gaffer\nprint ("LDTGAFFER:Update RenderNode layer menu")\nnode = plug.parent()\nglobals = node[\'out\'][\'globals\'].getValue()\nif \'option:LDT:layers\' in globals.keys():\n\tLDT_layers = globals[\'option:LDT:layers\']\nelse:\n\tLDT_layers = []\n# Variable member4 is the renderlayer\nplug_layers=node[\'layer\']\n\n\nmetadata = Gaffer.Metadata.registeredValues(plug_layers)\nfor key in metadata:\n\tif "preset" in key:\n\t\tprint ("LDTGAFFER:deregisterValue plug preset metadata: %s"%key)\n\t\tGaffer.Metadata.deregisterValue(plug_layers, key)\n\nGaffer.Metadata.registerValue( plug_layers, \'plugValueWidget:type\', \'GafferUI.PresetsPlugValueWidget\' )\n\nGaffer.Metadata.registerValue( plug_layers, \'preset:%s\'%"None", "" )\nfor layer in LDT_layers:\n\tprint ("LDTGAFFER:registerValue plug preset metadata: preset:%s"%layer) \n\tGaffer.Metadata.registerValue( plug_layers, \'preset:%s\'%layer, layer )\n' )
